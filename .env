PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=super_secret_enterprise_key_for_local_api_lab_12345
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=super_secret_refresh_key_for_local_api_lab_67890
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Configuration
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Simulation Configuration
ENABLE_MAINTENANCE_MODE=false
DEFAULT_DELAY_MS=0
SIMULATE_RANDOM_ERRORS=false
ERROR_PROBABILITY=0.1
